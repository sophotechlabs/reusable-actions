{
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
    "packages": {
        ".": {
            "release-type": "simple",
            "pull-request-header": ":robot: Release PR",
            "include-v-in-tag": true,
            "changelog-sections": [
                {
                    "type": "feat",
                    "section": "Features"
                },
                {
                    "type": "fix",
                    "section": "Bug Fixes"
                },
                {
                    "type": "chore",
                    "section": "Miscellaneous"
                },
                {
                    "type": "ci",
                    "section": "CI"
                },
                {
                    "type": "docs",
                    "section": "Documentation"
                },
                {
                    "type": "style",
                    "section": "Styles"
                },
                {
                    "type": "refactor",
                    "section": "Refactoring"
                },
                {
                    "type": "perf",
                    "section": "Performance"
                },
                {
                    "type": "test",
                    "section": "Tests"
                },
                {
                    "type": "build",
                    "section": "Build"
                },
                {
                    "type": "revert",
                    "section": "Reverts"
                }
            ]
        }
    }
}
